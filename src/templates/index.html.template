<!DOCTYPE html>
<html lang="{{DEFAULT_LANG}}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="TrolMaster Asia — Product Search Portal" />
  <title>TrolMaster Product Search</title>

  <!-- Inline CSS -->
  <style>
{{STYLES_CSS}}
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════
     OVERLAY
═════════════════════════════════════════ -->
<div class="overlay" id="overlay" onclick="closeMenu()"></div>

<!-- ══════════════════════════════════════════
     SIDEBAR
═════════════════════════════════════════ -->
<div class="sidebar" id="sidebar">
  <div class="sb-header">
    <h2 id="sbTitle">TM Testing Tools</h2>
    <button class="sb-close" onclick="closeMenu()">&times;</button>
  </div>
  <div class="sb-nav">
    <button class="sb-item active" data-page="product-search" onclick="navTo('product-search')">
      <span class="sb-icon">&#128269;</span>
      <span data-i18n="nav_product_search">Product Price and Stock</span>
    </button>
    <button class="sb-item disabled" data-page="tech-sheet">
      <span class="sb-icon">&#128196;</span>
      <span data-i18n="nav_tech_sheet">Tech sheet download</span>
      <span class="coming-soon" data-i18n="coming_soon">Coming Soon</span>
    </button>
    <button class="sb-item disabled" data-page="model-one">
      <span class="sb-icon">&#128290;</span>
      <span data-i18n="nav_cable_calculator">Model-One Calculator</span>
      <span class="coming-soon" data-i18n="coming_soon">Coming Soon</span>
    </button>
    <div class="sb-divider"></div>
    <button class="sb-item disabled" data-page="order-est">
      <span class="sb-icon">&#128178;</span>
      <span data-i18n="nav_orders_estimation">Order Estimation</span>
      <span class="coming-soon" data-i18n="coming_soon">Coming Soon</span>
    </button>
  </div>
  <div class="sb-footer">
    <p>&copy; 2026 Green Environmental Control</p>
    <p>TrolMaster Authorized Distributor</p>
  </div>
</div>

<!-- ══════════════════════════════════════════
     HEADER
═════════════════════════════════════════ -->
<header class="header">
  <div class="h-inner">
    <div class="h-left">
      <button class="menu-btn" onclick="openMenu()">&#9776;</button>
      <img class="logo-img" src="{{LOGO_DATA_URI}}" alt="TrolMaster Logo" />
      <div class="h-text">
        <h1 data-i18n="company_name">TrolMaster Asia Company Ltd</h1>
        <p class="header-sub" data-i18n="footer_data_source">Data sourced from Google Sheets</p>
      </div>
    </div>
    <div class="lang-switcher">
      <button class="lang-btn" id="langBtn">
        <span>EN</span>
        <span style="font-size:10px;">▼</span>
      </button>
      <div class="lang-dd" id="langDD">
        <div class="lang-opt" data-lang="en">English</div>
        <div class="lang-opt" data-lang="zh-Hant">繁體中文</div>
        <div class="lang-opt" data-lang="th">ภาษาไทย</div>
      </div>
    </div>
  </div>
</header>

<!-- ══════════════════════════════════════════
     PAGE: PRODUCT SEARCH
═════════════════════════════════════════ -->
<div class="page active" id="page-product-search">
  <div class="hero">
    <div class="hero-title" data-i18n="hero_title">TrolMaster Product Search</div>
    <div class="hero-sub" data-i18n="hero_sub">Enter model number for pricing and stock</div>
    <div class="s-wrap">
      <input type="text" id="q" data-i18n-placeholder="search_placeholder"
             placeholder="Enter product model, e.g.: WCS-9, NFS-2, ECW-1"
             autocomplete="off" />
      <button id="searchBtn" data-i18n="search_button">Search</button>
    </div>
    <div class="tags" id="tags"></div>
  </div>

  <!-- Status -->
  <div style="max-width:900px;margin:0 auto;padding:0 20px;">
    <div id="stockStatus" class="stock-status loading">⏳ Loading stock...</div>
  </div>

  <div class="res" id="res"></div>
</div>

<!-- ══════════════════════════════════════════
     PAGE: ORDER ESTIMATION
═════════════════════════════════════════ -->
<div class="page" id="page-order-est">
  <div class="coming-soon-page">
    <div class="cs-icon">&#128178;</div>
    <div class="cs-title" data-i18n="nav_orders_estimation">Order Estimation</div>
    <div class="cs-badge" data-i18n="coming_soon">Coming Soon</div>
    <div class="cs-desc" data-i18n="cs_order_est_desc">We're working on this feature. Stay tuned for order estimation tools!</div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     FOOTER
═════════════════════════════════════════ -->
<div class="footer">
  <span id="stockStatusBottom" class="stock-status loading">⏳ Loading stock...</span>
  &nbsp;&middot;&nbsp;
  &copy; 2026 <span data-i18n="company_name">TrolMaster Asia Co., Ltd.</span>
</div>

<!-- ══════════════════════════════════════════
     EMBEDDED DATA & SCRIPTS
═════════════════════════════════════════ -->
<script>
// Config injected by build_app.py
window.__TM_CONFIG__ = {{CONFIG_JSON}};

// i18n bundles
window.__TM_I18N__ = {{I18N_JSON}};

// Product translations (zh-Hant & th)
window.__TM_PRODUCT_TRANSLATIONS__ = {{PRODUCT_TRANSLATIONS_JSON}};

// Fallback product data (snapshot from build time)
window.__TM_PRODUCTS__  = {{PRODUCTS_JSON}};
window.__TM_INVENTORY__ = {{INVENTORY_JSON}};
</script>

<!-- Inline App JS -->
<script>
{{APP_JS}}
</script>

</body>
</html>
